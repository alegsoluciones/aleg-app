{
  "name": "aleg-app",
  "version": "2.0.0",
  "description": "Aleg Medic Infrastructure Root (Native Docker)",
  "scripts": {
    "bootstrap": "node scripts/bootstrap.js",
    "reset": "node scripts/reset.js",
    "seed": "node scripts/seed.js",
    "snapshot": "node scripts/snapshot.js",
    "restore": "node scripts/restore.js",
    "generate-map": "node scripts/generate-map.js",
    "dev": "node scripts/dev.js",
    "dev:code": "concurrently --names \"BACKEND,FRONTEND\" --prefix-colors \"blue,magenta\" \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:stop": "docker compose down",
    "dev:backend": "cd backend && npm run start:dev",
    "dev:frontend": "cd frontend && npm run dev",
    "prod": "docker compose -f docker-compose.prod.yml up -d --build",
    "prod:stop": "docker compose -f docker-compose.prod.yml down",
    "install:all": "npm install && npm run bootstrap && cd backend && npm install && cd ../frontend && npm install"
  },
  "keywords": [
    "aleg-app",
    "docker",
    "automation"
  ],
  "author": "Antigravity",
  "license": "UNLICENSED",
  "devDependencies": {
    "concurrently": "^8.2.0"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "dotenv": "^17.2.4",
    "fs-extra": "^11.3.3",
    "mysqldump": "^3.2.0"
  }
}
